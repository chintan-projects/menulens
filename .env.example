# Database
DATABASE_URL=postgresql+asyncpg://menulens:menulens@localhost:5432/menulens

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Maps
GOOGLE_MAPS_API_KEY=your-api-key-here

# LLM - Primary (ollama local)
OLLAMA_BASE_URL=http://localhost:11434
EXTRACTION_MODEL_PRIMARY=lfm2-8b-a1b

# LLM - Fallback (Claude API)
ANTHROPIC_API_KEY=your-api-key-here
EXTRACTION_MODEL_FALLBACK=claude-sonnet-4-20250514

# Extraction
EXTRACTION_CONFIDENCE_THRESHOLD=0.8

# Discovery
DISCOVERY_DEFAULT_RADIUS_MILES=5
DISCOVERY_MAX_RESULTS=200

# Storage
RAW_CONTENT_DIR=data/raw
EXTRACTED_CONTENT_DIR=data/extracted
