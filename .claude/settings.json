{
  "model": "claude-opus-4-6",
  "permissions": {
    "allow": [
      "Bash(git *)", "Bash(ls *)", "Bash(cat PROGRESS.yaml)", "Bash(cat BUGS.yaml)", "Bash(jq *)", "Bash(./scripts/*)", "Bash(gh *)", "Bash(make *)", "Bash(pytest *)", "Bash(python -m pytest *)", "Bash(python3 *)", "Bash(uv run *)", "Bash(black *)", "Bash(ruff *)", "Bash(mypy *)", "Bash(pip install *)",
      "mcp__github__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo *)",
      "Bash(curl * production*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "PYTHONPATH": "."
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Loading session state..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash-validate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-lint.sh",
            "timeout": 30,
            "statusMessage": "Auto-formatting..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/test-failure-notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-smoke-test.sh",
            "timeout": 120,
            "statusMessage": "Running smoke tests..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Review the git diff for this session. Check for: (1) files changed without corresponding test changes, (2) TODO/FIXME/HACK comments added without being tracked in BUGS.yaml, (3) obvious code quality issues (missing error handling, hardcoded values, print statements). Run: git diff --cached; git diff. If issues found: {\"ok\": false, \"reason\": \"<list issues>\"}. If clean: {\"ok\": true, \"reason\": \"Changes look clean.\"}.",
            "timeout": 120
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-completed-validate.sh",
            "timeout": 60,
            "statusMessage": "Validating task completion..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PRESERVE: modified files list, test results, current task, open blockers from BUGS.yaml, architecture decisions made this session'"
          }
        ]
      }
    ]
  }
}
